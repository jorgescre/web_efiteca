---
import Header from "@/components/common/Header.astro";
import Footer from "@/components/common/Footer.astro";
import SEOHead from "@/components/seo/SEOHead.astro";
import type { Lang } from "@/data/locales";
import { absoluteUrl, type AlternateLink } from "@/lib/seo/meta";
import "@/styles/global.css";

type Props = {
  lang: Lang;
  title: string;
  description: string;
  path: string;
  alternates?: AlternateLink[];
  image?: string;
  noindex?: boolean;
};

const { lang, title, description, path, alternates = [], image, noindex = false } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={absoluteUrl(path)}
      alternates={alternates}
      image={image}
      noindex={noindex}
    />
  </head>

  <body class="bg-sand text-ink antialiased">
    <div class="site-shell">
      <Header lang={lang} />
      <main>
        <slot />
      </main>
      <Footer lang={lang} />
    </div>
  </body>
</html>
