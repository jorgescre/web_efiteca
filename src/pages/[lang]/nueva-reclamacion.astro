---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ReactLegalPage } from "@/components/legal/ReactLegalPage";
import { ReactFormReclamacion } from "@/components/legal/ReactFormReclamacion";
import { LOCALES, type Lang } from "@/data/locales";
import { buildLanguageAlternates } from "@/lib/seo/meta";
import { getEntry, render } from "astro:content";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale.code }
  }));
}

const lang = Astro.params.lang as Lang;
const entry = await getEntry("pages", `nueva-reclamacion-${lang}`);

if (!entry) {
  return Astro.redirect(`/${lang}/404`);
}

const { Content } = await render(entry);
---

<BaseLayout
  lang={lang}
  title={entry.data.seo.title}
  description={entry.data.seo.description}
  path={`/${lang}/nueva-reclamacion/`}
  alternates={buildLanguageAlternates("/nueva-reclamacion/")}
>
  <div class="bg-[#f1f2f4]">
    <ReactLegalPage title={entry.data.title} client:idle>
      <Content />
    </ReactLegalPage>
    <!-- Form is outside the content prose area for correct full-width rendering -->
    <div class="mx-auto max-w-[900px] px-5 md:px-10 pb-24">
      <ReactFormReclamacion client:idle />
    </div>
  </div>
</BaseLayout>

