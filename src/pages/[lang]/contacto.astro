---
import ReactContactPage from "@/components/contact/ReactContactPage";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { LOCALES, type Lang } from "@/data/locales";
import { buildLanguageAlternates } from "@/lib/seo/meta";
import { getEntry } from "astro:content";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: {
      lang: locale.code
    }
  }));
}

const lang = Astro.params.lang as Lang;

const entry = await getEntry("pages", `contact-${lang}`);
let content = entry?.data;
let tinaProps:
  | {
      query: string;
      variables: Record<string, unknown>;
      data: Record<string, unknown>;
    }
  | undefined;

if (import.meta.env.DEV) {
  const query = `
    query ContactPage($relativePath: String!) {
      pages(relativePath: $relativePath) {
        id
        _sys {
          filename
          basename
          path
          breadcrumbs
          relativePath
          extension
        }
        lang
        title
        seo {
          title
          description
        }
        contactHero {
          eyebrow
          title
          highlight
          description
          primaryCta {
            label
            href
          }
          secondaryCta {
            label
            href
          }
        }
        contactIntro {
          pretitle
          title
          highlight
          bulletsTitle
          bullets
          footnote
          image
          floatingLabel
        }
        diagnosticSteps {
          title
          description
          footnote
          items {
            number
            title
            description
          }
        }
        contact {
          title
          description
          highlights
          scheduleLabel
          scheduleText
          phone
          email
          form {
            name_label
            name_placeholder
            lastname_label
            lastname_placeholder
            email_label
            email_placeholder
            phone_label
            phone_placeholder
            role_label
            role_placeholder
            message_label
            message_placeholder
            terms_label
            submit_label
          }
        }
        shortcutCta {
          title
          description
          image
          overlayImage
          accentImage
          button {
            label
            href
          }
        }
        locations {
          title
          subtitle
          items {
            city
            address
            image
            summary
            seoLabel
            cta {
              label
              href
            }
          }
        }
        faq {
          title
          items {
            question
            answer
          }
        }
      }
    }
  `;
  const variables = {
    relativePath: `contact-${lang}.md`
  };
  try {
    const response = await fetch("http://localhost:4001/graphql", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ query, variables })
    });
    const result = await response.json();

    if (result?.data?.pages) {
      content = result.data.pages;
      tinaProps = {
        query,
        variables,
        data: result.data
      };
    }
  } catch (error) {
    console.warn("[tina] GraphQL dev server not available, using local Astro content.", error);
  }
}

if (!content) {
  return Astro.redirect(`/${lang}/404`);
}

const faqItems = content.faq?.items ?? [];
---

<BaseLayout
  lang={lang}
  title={content.seo?.title || "Contacta con un asesor hipotecario — Efiteca"}
  description={content.seo?.description || "Habla con un experto hipotecario de Efiteca y recibe en 10 minutos un diagnóstico real sobre tu viabilidad. Sin compromiso. Disponible por WhatsApp o formulario."}
  path={`/${lang}/contacto/`}
  alternates={buildLanguageAlternates("/contacto/")}
>
  {faqItems.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item: { question: string; answer: string }) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })} />
  )}
  <ReactContactPage client:load content={content} {...tinaProps} />
</BaseLayout>
