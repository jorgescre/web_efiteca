---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ReactHome from "@/components/home/ReactHome.tsx";
import { LOCALES, type Lang } from "@/data/locales";
import { buildLanguageAlternates } from "@/lib/seo/meta";
import { getLatestNews } from "@/lib/content/news";

import { getEntry } from "astro:content";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: {
      lang: locale.code
    }
  }));
}

const lang = Astro.params.lang as Lang;
const latestNewsEntries = await getLatestNews(lang, 3);
const latestNews = latestNewsEntries.map((entry) => ({
  title: entry.data.title,
  description: entry.data.excerpt,
  image: entry.data.image || null,
  href: `/${lang}/news/${entry.slug}/`
}));

const entry = await getEntry("pages", `home-${lang}`);
let content = entry?.data;
let tinaProps:
  | {
      query: string;
      variables: Record<string, unknown>;
      data: Record<string, unknown>;
    }
  | undefined;

if (import.meta.env.DEV) {
  const query = `
    query HomePage($relativePath: String!) {
      pages(relativePath: $relativePath) {
        id
        _sys {
          filename
          basename
          path
          breadcrumbs
          relativePath
          extension
        }
        lang
        title
        seo {
          title
          description
        }
        hero {
          title_part1
          title_part2
          description
          background_desktop
          background_mobile
          cta {
            label
            href
          }
        }
        services {
          title
          description
          items {
            title
            description
            image
            button {
              label
              href
            }
          }
        }
        whoIsItFor {
          title
          items {
            title
            image
          }
          process {
            title
            requirements
            image
            pricing {
              title
              description
              highlight
              button {
                label
                href
              }
            }
          }
        }
        howItWorks {
          title
          description
          cta {
            label
            href
          }
          items {
            number
            title
            description
          }
        }
        steps {
          eyebrow
          title
          image
          items {
            number
            title
            description
          }
        }
        actionCta {
          title
          description
          button {
            label
            href
          }
        }
        benefits {
          title
          description
          ctaText
          ctaLink
          items {
            icon
            text
          }
        }
        metrics {
          title
          items {
            title
            value
          }
        }
        guides {
          title
          items {
            title
            cta {
              label
              href
            }
          }
        }
        testimonials {
          title
          backgroundColor
          description
          items {
            name
            role
            text
            image
            stars
          }
        }
        about {
          title
          description
          image
          badgeLabel
          badgeText
          button {
            label
            href
          }
        }
        partners {
          title
          description
          items {
            name
            image
          }
        }
        faq {
          title
          items {
            question
            answer
          }
        }
        locations {
          title
          subtitle
          items {
            city
            address
            image
            summary
            seoLabel
            cta {
              label
              href
            }
          }
        }
        blog {
          title
          subtitle
          cta {
            label
            href
          }
          items {
            title
            description
            image
            cta {
              label
              href
            }
          }
        }
        newsletter {
          title
          description
          emailPlaceholder
          button {
            label
            href
          }
        }
        contact {
          title
          description
          highlights
          form {
            name_label
            lastname_label
            email_label
            phone_label
            role_label
            role_placeholder
            message_label
            terms_label
            submit_label
          }
        }
        footer {
          services_title
          links {
            label
            href
          }
        }
      }
    }
  `;
  const variables = {
    relativePath: `home-${lang}.md`
  };
  const response = await fetch("http://localhost:4001/graphql", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      query,
      variables
    })
  });
  const payload = await response.json();

  tinaProps = {
    query,
    variables,
    data: payload.data
  };
  content = payload.data.pages;
}

if (!content) {
  return Astro.redirect(`/${lang}/404`);
}
---

<BaseLayout
  lang={lang}
  title={content.seo?.title || content.title}
  description={content.seo?.description}
  path={`/${lang}/`}
  alternates={buildLanguageAlternates("/")}
>
  <ReactHome client:load content={content} latestNews={latestNews} {...tinaProps} />
</BaseLayout>
