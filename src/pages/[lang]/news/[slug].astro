---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { type Lang } from "@/data/locales";
import { absoluteUrl } from "@/lib/seo/meta";
import { formatDate } from "@/lib/utils/format";
import { ReactBlogPost } from "@/components/blog/ReactBlogPost";

export async function getStaticPaths() {
  const entries = await getCollection("news");

  return entries.map((entry) => ({
    params: {
      lang: entry.data.lang,
      slug: entry.id
    },
    props: {
      entry
    }
  }));
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const { Content } = await render(entry);

// Related posts logic
const allNews = await getCollection("news", ({ data }) => data.lang === lang && data.title !== entry.data.title);
const relatedPosts = allNews.slice(0, 3).map(p => ({
  slug: p.id,
  title: p.data.title,
  excerpt: p.data.excerpt,
  lang: p.data.lang,
  image: p.data.image
}));

const alternates = [
  {
    hreflang: lang === "es" ? "es-ES" : "en",
    href: absoluteUrl(`/${lang}/news/${entry.id}/`)
  },
  {
    hreflang: "x-default",
    href: absoluteUrl(`/${lang}/news/${entry.id}/`)
  }
];

const articleUrl = absoluteUrl(`/${lang}/news/${entry.id}/`);
const articleImage = entry.data.image
  ? (entry.data.image.startsWith("http") ? entry.data.image : absoluteUrl(entry.data.image))
  : absoluteUrl("/images/og-default.svg");

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.seo.description,
  "image": articleImage,
  "datePublished": entry.data.publishedAt,
  "dateModified": entry.data.publishedAt,
  "author": {
    "@type": "Organization",
    "name": "Efiteca",
    "url": "https://www.efiteca.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Efiteca",
    "logo": {
      "@type": "ImageObject",
      "url": absoluteUrl("/images/favicon-efiteca.svg")
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl
  },
  "url": articleUrl,
  "inLanguage": lang === "es" ? "es-ES" : "en"
};
---

<BaseLayout
  lang={lang}
  title={entry.data.seo.title}
  description={entry.data.seo.description}
  path={`/${lang}/news/${entry.id}/`}
  alternates={alternates}
  ogType="article"
  image={entry.data.image}
>
  <!-- Schema.org: Article -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <!-- Schema.org: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": lang === "en" ? "Home" : "Inicio",
        "item": absoluteUrl(`/${lang}/`)
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": absoluteUrl(`/${lang}/news/`)
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": entry.data.title,
        "item": absoluteUrl(`/${lang}/news/${entry.id}/`)
      }
    ]
  })} />

  <ReactBlogPost
    client:load
    title={entry.data.title}
    category={entry.data.category}
    publishedAt={formatDate(entry.data.publishedAt, lang)}
    excerpt={entry.data.excerpt}
    image={entry.data.image}
    relatedPosts={relatedPosts}
  >
    <Content />
  </ReactBlogPost>
</BaseLayout>
