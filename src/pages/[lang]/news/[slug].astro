---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { type Lang } from "@/data/locales";
import { absoluteUrl } from "@/lib/seo/meta";
import { formatDate } from "@/lib/utils/format";
import { ReactBlogPost } from "@/components/blog/ReactBlogPost";

export async function getStaticPaths() {
  const entries = await getCollection("news");

  return entries.map((entry) => ({
    params: {
      lang: entry.data.lang,
      slug: entry.slug
    },
    props: {
      entry
    }
  }));
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const { Content } = await render(entry);

// Related posts logic
const allNews = await getCollection("news", ({ data }) => data.lang === lang && data.title !== entry.data.title);
const relatedPosts = allNews.slice(0, 3).map(p => ({
  slug: p.slug,
  title: p.data.title,
  excerpt: p.data.excerpt,
  lang: p.data.lang,
  image: undefined // news schema has no image field; ReactBlogPost shows emoji fallback
}));

const alternates = [
  {
    hreflang: lang === "es" ? "es-ES" : "en",
    href: absoluteUrl(`/${lang}/news/${entry.slug}/`)
  },
  {
    hreflang: "x-default",
    href: absoluteUrl(`/${lang}/news/${entry.slug}/`)
  }
];
---

<BaseLayout
  lang={lang}
  title={entry.data.seo.title}
  description={entry.data.seo.description}
  path={`/${lang}/news/${entry.slug}/`}
  alternates={alternates}
>
  <ReactBlogPost 
    client:load 
    title={entry.data.title}
    category={entry.data.category}
    publishedAt={formatDate(entry.data.publishedAt, lang)}
    excerpt={entry.data.excerpt}
    relatedPosts={relatedPosts}
  >
    <Content />
  </ReactBlogPost>
</BaseLayout>
