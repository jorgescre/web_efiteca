---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { LOCALES, type Lang } from "@/data/locales";
import { buildLanguageAlternates } from "@/lib/seo/meta";
import { getNewsForLang } from "@/lib/content/news";
import { formatDate } from "@/lib/utils/format";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: {
      lang: locale.code
    }
  }));
}

const lang = Astro.params.lang as Lang;
const entries = await getNewsForLang(lang);

const copy = {
  es: {
    title: "Noticias | Efiteca",
    description: "Noticias, analisis e hitos corporativos de Efiteca por idioma y mercado.",
    heading: "Noticias y analisis"
  },
  en: {
    title: "News | Efiteca",
    description: "News, analysis and corporate updates from Efiteca across languages and markets.",
    heading: "News and analysis"
  }
};
---

<BaseLayout
  lang={lang}
  title={copy[lang].title}
  description={copy[lang].description}
  path={`/${lang}/news/`}
  alternates={buildLanguageAlternates("/news/")}
>
  <section class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <p class="text-sm uppercase tracking-[0.18em] text-coral">Journal</p>
    <h1 class="mt-4 font-display text-5xl text-ink">{copy[lang].heading}</h1>

    <div class="mt-10 grid gap-5">
      {
        entries.map((entry) => (
          <article class="rounded-[30px] border border-ink/10 bg-white/75 p-7 shadow-card">
            <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.18em] text-coral">
              <span>{entry.data.category}</span>
              <span>{formatDate(entry.data.publishedAt, lang)}</span>
            </div>
            <h2 class="mt-4 font-display text-3xl text-ink">
              <a href={`/${lang}/news/${entry.slug}/`}>{entry.data.title}</a>
            </h2>
            <p class="mt-3 max-w-3xl text-base leading-7 text-ink/70">{entry.data.excerpt}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
