---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ReactBlogPage from "@/components/blog/ReactBlogPage";
import { LOCALES, type Lang } from "@/data/locales";
import { buildLanguageAlternates } from "@/lib/seo/meta";
import { getEntry, getCollection } from "astro:content";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: {
      lang: locale.code
    }
  }));
}

const lang = Astro.params.lang as Lang;

const entry = await getEntry("pages", `blog-${lang}`);
let content = entry?.data;
let tinaProps:
  | {
      query: string;
      variables: Record<string, unknown>;
      data: Record<string, unknown>;
    }
  | undefined;

if (import.meta.env.DEV) {
  const query = `
    query BlogPage($relativePath: String!) {
      pages(relativePath: $relativePath) {
        id
        _sys {
          filename
          basename
          path
          breadcrumbs
          relativePath
          extension
        }
        lang
        title
        seo {
          title
          description
        }
        newsLanding {
          heroTitle
          heroHighlight
          heroDescription
          listingTitle
          listingDescription
        }
        blog {
          title
          subtitle
          cta {
            label
            href
          }
          items {
            title
            description
            image
            cta {
              label
              href
            }
          }
        }
        newsletter {
          title
          description
          emailPlaceholder
          button {
            label
            href
          }
        }
        actionCta {
          title
          description
          button {
            label
            href
          }
        }
      }
    }
  `;
  const variables = {
    relativePath: `blog-${lang}.md`
  };
  const response = await fetch("http://localhost:4001/graphql", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ query, variables })
  });
  const result = await response.json();

  if (result?.data?.pages) {
    content = result.data.pages;
    tinaProps = {
      query,
      variables,
      data: result.data
    };
  }
}

if (!content) {
  return Astro.redirect(`/${lang}/404`);
}

const newsEntries = await getCollection("news", ({ data }) => data.lang === lang);
const sortedNews = newsEntries.sort((a, b) => b.data.publishedAt.localeCompare(a.data.publishedAt));
const newsItems = sortedNews.map((entry) => ({
  title: entry.data.title,
  description: entry.data.excerpt,
  image: entry.data.image,
  href: `/${lang}/news/${entry.id}/`,
}));
---

<BaseLayout
  lang={lang}
  title={content.seo?.title || (lang === "es" ? "Blog hipotecario — Consejos y guías — Efiteca" : "Mortgage Blog — Tips & Guides — Efiteca")}
  description={content.seo?.description || (lang === "es" ? "Guías, consejos y artículos sobre hipotecas en España. Aprende cómo comprar vivienda, mejorar tu hipoteca y acceder al mejor financiamiento con Efiteca." : "Guides, tips and articles about mortgages in Spain. Learn how to buy a home and get the best financing with Efiteca.")}
  path={`/${lang}/news/`}
  alternates={buildLanguageAlternates("/news/")}
>
  <ReactBlogPage client:idle content={content} {...tinaProps} lang={lang} newsItems={newsItems} />
</BaseLayout>
