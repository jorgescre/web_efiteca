---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildLanguageAlternates } from "@/lib/seo/meta";
---

<BaseLayout
  lang="es"
  title="Pagina no encontrada | Efiteca"
  description="La pagina solicitada no existe o fue movida."
  path="/404/"
  alternates={buildLanguageAlternates("/")}
  noindex={true}
>
  <section class="mx-auto max-w-4xl px-6 py-24 text-center">
    <p class="text-sm uppercase tracking-[0.18em] text-coral">404</p>
    <h1 class="mt-4 font-display text-5xl text-ink">Pagina no encontrada</h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-ink/70">
      La ruta que buscas no esta disponible en esta version del sitio.
    </p>
    <a
      href="/es/"
      class="mt-10 inline-flex rounded-full bg-pine px-6 py-3 text-sm font-medium text-sand transition hover:bg-ink"
    >
      Volver al inicio
    </a>
  </section>
</BaseLayout>
