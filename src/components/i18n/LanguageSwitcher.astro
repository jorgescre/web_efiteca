---
import { LOCALES, type Lang } from "@/data/locales";
import { stripLangFromPath, withLang } from "@/lib/i18n/routes";

type Props = {
  currentLang: Lang;
  currentPath: string;
};

const { currentLang, currentPath } = Astro.props;
const relativePath = stripLangFromPath(currentPath);
---

<div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/5 p-1">
  {
    LOCALES.map((locale) => {
      const isActive = locale.code === currentLang;

      return (
        <a
          href={withLang(locale.code, relativePath)}
          class:list={[
            "rounded-full px-3 py-1.5 text-xs font-medium transition",
            isActive ? "bg-gold text-ink" : "text-sand/80 hover:bg-white/10 hover:text-sand"
          ]}
        >
          {locale.label}
        </a>
      );
    })
  }
</div>
