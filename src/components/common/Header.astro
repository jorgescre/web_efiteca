---
import { NAV_ITEMS } from "@/data/navigation";
import type { Lang } from "@/data/locales";
import LanguageSwitcher from "@/components/i18n/LanguageSwitcher.astro";

type Props = {
  lang: Lang;
};

const { lang } = Astro.props;
---

<header class="site-header">
  <div class="site-container site-header__inner">
    <a href={`/${lang}/`} class="brand-mark text-sand">
      Efiteca
    </a>

    <div class="flex items-center gap-6">
      <nav aria-label="Primary" class="hidden gap-5 md:flex">
        {
          NAV_ITEMS.map((item) => (
            <a class="nav-link" href={`/${lang}${item.href}`}>
              {item.label[lang]}
            </a>
          ))
        }
      </nav>

      <LanguageSwitcher currentLang={lang} currentPath={Astro.url.pathname} />
    </div>
  </div>
</header>
