---
import type { Lang } from "@/data/locales";

type Props = {
  lang: Lang;
};

const { lang } = Astro.props;

const copy = {
  es: {
    tagline: "Arquitectura digital para mercados inmobiliarios y capital privado.",
    legal: "Boilerplate inicial. Ajusta textos legales, cookies y dominio antes de salir a produccion."
  },
  en: {
    tagline: "Digital architecture for real estate markets and private capital.",
    legal: "Sitio base. Actualiza el texto legal, cookies y dominio final antes de publicar."
  }
};
---

<footer class="border-t border-ink/10 bg-sand/60">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-10 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="font-display text-xl text-ink">Efiteca</p>
      <p class="mt-2 max-w-xl text-sm text-ink/70">{copy[lang].tagline}</p>
    </div>

    <p class="max-w-md text-sm text-ink/60">{copy[lang].legal}</p>
  </div>
</footer>
