---
import type { Lang } from "@/data/locales";
import { getMarketsForLang } from "@/data/markets";

type Props = {
  lang: Lang;
};

const { lang } = Astro.props;
const markets = getMarketsForLang(lang);
---

<div class="grid gap-5 md:grid-cols-3">
  {
    markets.map((market) => (
      <a
        href={`/${lang}/${market.slug}/`}
        class="group rounded-[28px] border border-ink/10 bg-white/80 p-6 shadow-card transition hover:-translate-y-1 hover:border-gold/40"
      >
        <p class="text-xs uppercase tracking-[0.16em] text-coral">{market.countryCode}</p>
        <h3 class="mt-3 font-display text-2xl text-ink">{market.label[lang]}</h3>
        <p class="mt-3 text-sm leading-6 text-ink/70">{market.hero[lang]}</p>
        <span class="mt-6 inline-flex text-sm font-medium text-pine group-hover:text-coral">
          {lang === "es" ? "Explorar mercado" : "Explore market"}
        </span>
      </a>
    ))
  }
</div>
